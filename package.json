{
  "name": "daily-habit",
  "private": true,
  "author": "Daily Habit <noreply@daily-habit.app>",
  "version": "0.1.7",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "preversion": "pnpm build",
    "dev": "vite",
    "build": "node scripts/generate-icons.mjs && tsc -b && vite build",
    "build:cf": "VITE_BASE_URL=/ pnpm build",
    "lint": "eslint .",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "cap:sync": "cap sync android",
    "cap:open:android": "cap open android",
    "android:build": "VITE_BASE_URL=/ pnpm build && cap sync android && cd android && ./gradlew assembleDebug",
    "android:run": "pnpm android:build && adb -s ${ANDROID_SERIAL:-$(adb devices | sed -n '2p' | cut -f1)} install -r android/app/build/outputs/apk/debug/app-debug.apk && adb -s ${ANDROID_SERIAL:-$(adb devices | sed -n '2p' | cut -f1)} shell am start -n com.dailyhabit.app/.MainActivity",
    "android:devices": "adb devices -l",
    "android:dev": "export DEVICE=${ANDROID_SERIAL:-$(adb devices | sed -n '2p' | cut -f1)} && adb -s $DEVICE reverse tcp:5173 tcp:5173 && CAP_LIVERELOAD=1 cap run android --livereload --external",
    "electron:dev": "ELECTRON=1 pnpm build && electron .",
    "electron:build": "ELECTRON=1 pnpm build && electron-builder"
  },
  "devDependencies": {
    "@capacitor-community/sqlite": "^6.0.2",
    "@capacitor/android": "^6.2.0",
    "@capacitor/cli": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.0.10",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^10.4.1",
    "i18next": "^26.3.0",
    "kysely": "^0.28.0",
    "lucide-react": "^0.469.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.28.1",
    "sharp": "^0.34.5",
    "sqlocal": "^0.18.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^0.21.1",
    "webdav": "^5.8.0",
    "workbox-window": "^7.3.0",
    "wrangler": "^4.96.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  }
}
